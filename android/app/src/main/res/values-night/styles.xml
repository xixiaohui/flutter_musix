<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark Launch Theme -->
    <style name="LaunchTheme" parent="@android:style/Theme.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:statusBarColor">#121212</item>
        <item name="android:navigationBarColor">#121212</item>
    </style>

    <!-- Dark Normal Theme — behind Flutter UI -->
    <style name="NormalTheme" parent="@android:style/Theme.NoTitleBar">
        <item name="android:windowBackground">#121212</item>
        <item name="android:statusBarColor">#121212</item>
        <item name="android:navigationBarColor">#121212</item>
    </style>
</resources>
