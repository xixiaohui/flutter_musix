<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Light Launch Theme — shown while Flutter engine initializes -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:statusBarColor">#FAFAFA</item>
        <item name="android:navigationBarColor">#FAFAFA</item>
    </style>

    <!-- Light Normal Theme — behind Flutter UI -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">#FAFAFA</item>
        <item name="android:statusBarColor">#FAFAFA</item>
        <item name="android:navigationBarColor">#FAFAFA</item>
    </style>
</resources>
